# Data360 Voice - Environment Variables

# =============================================================================
# REQUIRED — app will not start without these
# =============================================================================

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string — required for app startup and Chainlit SQLAlchemy conversation persistence
# Conversations are saved to PostgreSQL and users can resume previous chats from the sidebar.
# The +asyncpg protocol conversion is handled automatically by app/data.py.
DATABASE_URL=postgresql://user:password@localhost:5432/data360voice

# Chainlit auth secret — required for authentication (conversation history sidebar won't work without it)
# Must be passed as a shell env var (not loaded from .env by Chainlit automatically).
# Generate a strong random value for production: openssl rand -hex 32
# For local dev any 32+ char string works.
CHAINLIT_AUTH_SECRET=change-me-to-a-long-random-secret-for-prod

# =============================================================================
# OPTIONAL — overrides and tuning
# =============================================================================

# Data360 API
# DATA360_BASE_URL=https://data360api.worldbank.org
# DATA360_REQUEST_TIMEOUT=30
# DATA360_MAX_RETRIES=3
# DATA360_RETRY_BACKOFF_BASE=1.0

# MCP
# MCP_SERVER_URL=http://localhost:8001/mcp
MCP_PORT=8001

# Service ports (used by justfile dev commands)
APP_PORT=8000

# Claude model for the chat backend (default: claude-haiku-4-5)
# CLAUDE_MODEL=claude-haiku-4-5

# Maximum tokens per Claude response (default: 4096)
# CLAUDE_MAX_TOKENS=4096

# Maximum characters for tool result text sent back to Claude (default: 50000)
# TOOL_RESULT_MAX_CHARS=50000

# Maximum number of conversation messages passed as context to Claude (default: 10)
# CONVERSATION_HISTORY_LIMIT=10

# Feature Flags
DATA360_RAG_ENABLED=false  # Set to true to enable document upload and RAG search
