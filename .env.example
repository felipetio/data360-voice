# Data360 Voice - Environment Variables

# Data360 API (optional overrides, defaults are sensible)
# DATA360_BASE_URL=https://data360api.worldbank.org
# DATA360_REQUEST_TIMEOUT=30
# DATA360_MAX_RETRIES=3
# DATA360_RETRY_BACKOFF_BASE=1.0

# Anthropic API key (required for web app — Claude integration)
# ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string — activates Chainlit SQLAlchemy conversation persistence
# When set, conversations are saved to PostgreSQL and users can resume previous chats
# The +asyncpg protocol conversion is handled automatically by app/data.py
# DATABASE_URL=postgresql://user:password@localhost:5432/data360voice

# MCP
# MCP_SERVER_URL=http://localhost:8001/mcp
# MCP_TRANSPORT=streamable-http
# MCP_PORT=8001

# Claude model for the chat backend (optional — default: claude-haiku-4-5)
# CLAUDE_MODEL=claude-haiku-4-5

# Maximum tokens per Claude response (optional — default: 4096)
# CLAUDE_MAX_TOKENS=4096

# Maximum characters for tool result text sent back to Claude (optional — default: 50000)
# TOOL_RESULT_MAX_CHARS=50000

# Maximum number of conversation messages passed as context to Claude (optional — default: 10)
# CONVERSATION_HISTORY_LIMIT=10
